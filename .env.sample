# =============================================================================
# MORNING MAILER - ENVIRONMENT VARIABLES
# =============================================================================

# =============================================================================
# MODEL
# =============================================================================
MODEL_PROVIDER=openrouter
MODEL_TEMPERATURE=0.4
MAX_TOKENS=10500


# =============================================================================
# OPENAI
# =============================================================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-nano


# =============================================================================
# NVIDIA
# =============================================================================
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_MODEL=qwen/qwen3-next-80b-a3b-instruct


# =============================================================================
# OPENROUTER
# =============================================================================
OPEN_ROUTER_API_KEY=your-openrouter-api-key-here
OPEN_ROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash
OPEN_ROUTER_BASE_URL=https://api.openrouter.ai


# =============================================================================
# GOOGLE GEMINI
# =============================================================================
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.5-flash


# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://:testpass@valkey:6379/0


# =============================================================================
# EMAIL (SMTP) - Fallback if not defined in users.json
# =============================================================================
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here


# =============================================================================
# Cron Job Configs
# =============================================================================
RETRY_COUNT=2
RETRY_DELAY=60
MAX_EMAIL_RESULTS=20
SCHEDULE_TIME=08:00
DAYS_THRESHOLD=1
MAX_THREAD_WORKERS=5
SCHEDULE_CHECK_INTERVAL=5


# =============================================================================
# Environment Mode
# =============================================================================
# dev  = run multiple times per day (skip last_run check) + verbose DEBUG logs
# prod = run once per day (enforce last_run check) + quiet SUCCESS-level logs
ENV_MODE=dev


# =============================================================================
# OAuth Callback URL
# =============================================================================
# For web OAuth: defaults to http://localhost:47433/callback
# Override with ngrok URL for remote OAuth: https://your-ngrok.io/callback
OAUTH_CALLBACK_URL=http://localhost:47433/callback


# =============================================================================
# USERS — Stored in Redis (Valkey)
# =============================================================================
# Users are stored as Redis hashes using the pattern:
#   USERS_CONFIG:<keyword>
#
# Each hash contains the same fields as users.json:
#   name, email, keyword, active, use_email, use_whatsapp,
#   max_email_results, days_threshold, schedule_time,
#   smtp_host_user, smtp_host_password, mobile
#
# Manage users via CLI:  python cli_users.py list|add|update|remove|...
#            or IPython: %redis_users_list, %redis_users_add, etc.
#
# If no Redis users exist, the system falls back to users.json.


# =============================================================================
# WHATSAPP (WAHA)
# =============================================================================
WAHA_API_URL=http://waha:3000
WAHA_API_KEY=your-waha-api-key-here
WAHA_SESSION=default